# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aiplatform:aiplatform@localhost:5432/aiplatform

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-prod-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── LLM / Ray Serve ───────────────────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8000
EMBEDDING_BASE_URL=http://localhost:8000
RAY_ADDRESS=ray://localhost:10001

# ── HuggingFace (for vLLM model download) ─────────────────────────────────
HF_TOKEN=hf_your_token_here

# ── Model Names ───────────────────────────────────────────────────────────
DEFAULT_CHAT_MODEL=qwen3.5-plus
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# ── GPU Mode ──────────────────────────────────────────────────────────────
# Set to true to enable GPU for vLLM
ENABLE_GPU=false

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXTAUTH_SECRET=frontend-secret-change-in-prod

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

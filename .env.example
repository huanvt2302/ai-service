# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aiplatform:aiplatform@localhost:5432/aiplatform

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-prod-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── LLM / llama.cpp ────────────────────────────────────────────────────────────
LLM_BASE_URL=http://llama-cpp:8080/v1
EMBEDDING_BASE_URL=http://llama-cpp:8080/v1

# llama.cpp model settings (GGUF format)
LLAMA_CPP_MODEL=qwen2.5-3b-instruct-q4_k_m.gguf
LLAMA_CPP_CTX_SIZE=8192
LLAMA_CPP_THREADS=4

# ── HuggingFace (for vLLM model download) ─────────────────────────────────
HF_TOKEN=hf_your_token_here

# ── Model Names ───────────────────────────────────────────────────────────
DEFAULT_CHAT_MODEL=qwen3.5-plus
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:80
NEXTAUTH_SECRET=frontend-secret-change-in-prod

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:80

# ══════════════════════════════════════════════════════════════════════════
# HYBRID CLOUD BURST — Docker Swarm + GCP Cloud Run
# ══════════════════════════════════════════════════════════════════════════

# ── Swarm Cluster ─────────────────────────────────────────────────────────
# IP of Machine 1 (Manager node)
MACHINE1_IP=192.168.1.10
MACHINE2_IP=192.168.1.11
MACHINE3_IP=192.168.1.12

# Docker image registry (local registry on Machine 1)
REGISTRY=localhost:5000
TAG=latest

# DB password for Swarm (used by postgres service)
DB_PASSWORD=change-me-strong-password

# ── Hybrid Router ─────────────────────────────────────────────────────────
# CPU % threshold on local cluster to trigger cloud burst (default: 70)
BURST_THRESHOLD=70
# CPU % threshold to scale cloud back to 0 (default: 40)
SCALE_DOWN_THRESHOLD=40

# Cloud Run URL (filled automatically by burst-gcp.sh deploy, or set manually)
CLOUD_BACKEND_URL=

# ── GCP Cloud Run Burst ───────────────────────────────────────────────────
GCP_PROJECT=ai-service-prod
GCP_REGION=asia-southeast1
CLOUD_RUN_SERVICES=ai-backend,ai-vllm
# Number of Cloud Run min-instances when bursting (pre-warmed)
BURST_MIN_INSTANCES=2

# Cloud infrastructure (auto-filled by burst-gcp.sh)
DATABASE_URL_CLOUD=
REDIS_URL_CLOUD=
GCS_BUCKET=

# GCP Service Account key path (for burst-controller)
# GCP_SA_KEY_PATH=/path/to/sa-key.json
